<div class="sidebar-container">
  <%= render "shared/sidebar" %>
<div class="page-edit">
  <div class="container">
    <h2><%= t('devise.registrations.edit_title', resource: resource_name.to_s.humanize) %></h2>

    <%= form_for(resource, as: resource_name, url: registration_path(resource_name), html: { method: :put }) do |f| %>
      <%= render "devise/shared/error_messages", resource: resource %>

      <div class="field">
        <%= f.label :email, t('devise.attributes.email') %><br />
        <%= f.email_field :email, autofocus: true, autocomplete: "email" %>
      </div>

      <% if devise_mapping.confirmable? && resource.pending_reconfirmation? %>
        <div>Currently waiting confirmation for: <%= resource.unconfirmed_email %></div>
      <% end %>

      <div class="field">
        <%= f.label :password, t('devise.attributes.password') %> <i><%= t('devise.registrations.leave_blank') %></i><br />
        <%= f.password_field :password, autocomplete: "new-password" %>
        <% if @minimum_password_length %>
          <br />
          <em><%= @minimum_password_length %> minimo de caracteres</em>
        <% end %>
      </div>

      <div class="field">
        <%= f.label :password_confirmation, t('devise.attributes.password_confirmation') %><br />
        <%= f.password_field :password_confirmation, autocomplete: "new-password" %>
      </div>

      <div class="field">
        <%= f.label :current_password, t('devise.attributes.current_password') %> <i><%= t('devise.registrations.current_password_note') %></i><br />
        <%= f.password_field :current_password, autocomplete: "current-password" %>
      </div>

      <div class="actions">
        <%= f.submit t('devise.registrations.update_button') %>
      </div>
    <% end %>
    <div>
      <%= button_to t('devise.registrations.cancel_account'), registration_path(resource_name), data: { confirm: t('devise.registrations.cancel_confirm'), turbo_confirm: t('devise.registrations.cancel_confirm') }, method: :delete %>
    </div>
  </div>
</div>
