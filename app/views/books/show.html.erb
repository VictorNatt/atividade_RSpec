<div class="page-books">
  <div class="container">
    <h1><%= @book.title %></h1>
    <p><strong>Autor:</strong> <%= @book.author %></p>
    <p><strong>Descrição:</strong> <%= @book.description %></p>

    <hr>

    <div class="action">
      <%= link_to "Voltar", books_path, class: "btn btn-link" %>
      <% if policy(@book).edit? %>
         <%= link_to "Editar", edit_book_path(@book), class: "btn btn-link"%>
      <% end %>

      <% if policy(@book).destroy? %>
         <%= button_to "Excluir", @book, method: :delete, data: { confirm: "Tem certeza?" } %>
      <% end %>
    </div>
  </div>
</div>